-- LÓGICA ESP (LINHA NA BARRIGA)
local function CreateESP(p)
    RunService.RenderStepped:Connect(function()
        if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
            local hrp = p.Character.HumanoidRootPart
            
            -- BOX
            local box = hrp:FindFirstChild("KZZ_Box") or Instance.new("BillboardGui", hrp)
            box.Name = "KZZ_Box"; box.AlwaysOnTop = true; box.Size = UDim2.new(4, 0, 6, 0); box.Enabled = getgenv().ESP_Box
            local f = box:FindFirstChild("F") or Instance.new("Frame", box)
            f.Name = "F"; f.Size = UDim2.new(1,0,1,0); f.BackgroundTransparency = 1
            local s = f:FindFirstChild("S") or Instance.new("UIStroke", f)
            s.Thickness = 1.2; s.Color = Color3.new(0,0,0); s.Transparency = 0.5

            -- BEAM (LINHA NA BARRIGA)
            local att0 = hrp:FindFirstChild("KZZ_Att0") or Instance.new("Attachment", hrp)
            att0.Name = "KZZ_Att0"
            att0.Position = Vector3.new(0, 0, 0) -- Posição 0 é a BARRIGA

            local att1 = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") and Player.Character.HumanoidRootPart:FindFirstChild("KZZ_AttBase") or nil
            if not att1 and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                att1 = Instance.new("Attachment", Player.Character.HumanoidRootPart)
                att1.Name = "KZZ_AttBase"; att1.Position = Vector3.new(0, -3.5, 0) -- Sai do seu pé
            end

            local beam = hrp:FindFirstChild("KZZ_Beam") or Instance.new("Beam", hrp)
            beam.Name = "KZZ_Beam"
            beam.Attachment0 = att0
            beam.Attachment1 = att1
            beam.Width0 = 0.1
            beam.Width1 = 0.1
            beam.Color = ColorSequence.new(Color3.new(0,0,0))
            beam.Transparency = NumberSequence.new(0.5)
            beam.FaceCamera = true
            beam.Enabled = getgenv().ESP_Lines
        end
    end)
end

-- AIMBOT
local function GetClosest()
    local t, d = nil, 500
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= Player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character.Humanoid.Health > 0 then
            local p, vis = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
            if vis then
                local mag = (Vector2.new(p.X, p.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if mag < d then d = mag; t = v.Character.HumanoidRootPart end
            end
        end
    end
    return t
end

RunService.RenderStepped:Connect(function()
    local target = GetClosest()
    if target then
        if getgenv().Aimbot_Lock then Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position)
        elseif getgenv().Aimbot_Smooth then Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Position), 0.08) end
    end
end)

for _, p in pairs(Players:GetPlayers()) do if p ~= Player then CreateESP(p) end end
Players.PlayerAdded:Connect(function(p) if p ~= Player then CreateESP(p) end end)
